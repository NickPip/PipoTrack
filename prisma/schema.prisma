generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  RECRUITING
  DISPATCHER
  OPERATIONS
  ACCOUNTING
}

enum LoadStatus {
  // ── Dispatch phase ──────────────────────────────
  PENDING_DISTRIBUTION  // sent to drivers, awaiting bids  (All tab)
  HAS_BIDS              // at least one driver bid         (New tab)
  QUOTED                // dispatcher priced, sent broker  (Quoted tab)
  BOOKED                // broker confirmed, enters Ops
  // ── Operations phase ────────────────────────────
  PENDING
  DISPATCHED_TO_PICKUP
  ONSITE_FOR_PICKUP
  LOADED_AND_DELIVERING
  ONSITE_FOR_DELIVERY
  DELIVERED
  CANCELED
}

enum FinStatus {
  UNPAID
  PENDING
  PAID
}

model User {
  id               String   @id @default(cuid())
  name             String
  surname          String
  email            String   @unique
  password         String
  idNumber         String   @unique
  role             Role
  phoneNumber      String
  phone2           String?
  address          String?
  emergencyContact String?
  createdAt        DateTime @default(now())
}

model Owner {
  id            String  @id @default(cuid())
  name          String
  ownerName     String?
  email         String
  phone         String
  address       String?
  ssnFein       String?
  ssnFeinDocUrl String?
  ownerDocUrl   String?
  company       String?
  bankInfoUrl   String?
  w9Url         String?
  insuranceUrl  String?
}

model Unit {
  id              String   @id @default(cuid())
  unitNumber      String
  type            String
  make            String?
  model           String?
  year            String?
  vin             String?
  plateNumber     String?
  ownerId         String?
  payload         Float?
  equipment       Json?
  dimensions      Json?
  registrationUrl String?
  pictureUrls     Json?
  available       Boolean  @default(true)
  drivers         Driver[]
}

model Driver {
  id               String           @id @default(cuid())
  name             String
  phone            String?
  address          String?
  dlNumber         String?
  dlDocumentUrl    String?
  citizenshipType  String?
  cleanBackground  Boolean?
  emergencyContact String?
  drivingRecordUrl String?
  twicTsaUrl       String?
  appUsername      String?
  appPassword      String?
  vehicleType      String?
  currentZip       String?
  searchRadius     Int?
  telegramId       String?
  traccarDeviceId  String?
  unitId           String?
  outMiles         Int?
  minMiles         Int?             @default(0)
  maxMiles         Int?             @default(5000)
  wayDirection     String?          @default("ANY")
  isAvailable      Boolean          @default(true)
  availableAt      DateTime?
  unit             Unit?            @relation(fields: [unitId], references: [id])
  bids             Bid[]
  location         DriverLocation?
}

model DriverLocation {
  id        String   @id @default(cuid())
  driverId  String   @unique
  lat       Float
  lon       Float
  speed     Float?
  bearing   Float?
  altitude  Float?
  accuracy  Float?
  updatedAt DateTime @updatedAt
  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
}

model Load {
  id              String     @id @default(cuid())
  loadNumber      Int        @default(autoincrement())
  status          LoadStatus @default(PENDING_DISTRIBUTION)
  financialStatus FinStatus  @default(UNPAID)
  broker          String
  brokerName      String?
  brokerEmail     String?
  brokerPhone     String?
  brokerReference String?
  pickupZip       String?
  pickupAddress   String
  pickupDate      DateTime
  pickupNotes     String?
  deliveryAddress String
  deliveryZip     String?
  deliveryDate    DateTime
  deliveryNotes   String?
  stackable       Boolean?
  rate            Float?
  driverRate      Float?
  miles           Float?
  weight          Float?
  dimensions      Json?
  vehicleRequired String?
  rcUrl           String?
  bolUrls         Json?
  podUrl          String?
  factoringStatus String?
  rcUploaded      Boolean    @default(false)
  dispatcherId    String?
  trackingId      String?
  driverId        String?
  unitId          String?
  createdAt       DateTime   @default(now())
  bids            Bid[]
  notes           LoadNote[]
}

model Bid {
  id        String   @id @default(cuid())
  loadId    String
  driverId  String
  amount    Float
  status    String
  createdAt DateTime @default(now())
  load      Load     @relation(fields: [loadId], references: [id])
  driver    Driver   @relation(fields: [driverId], references: [id])
}

model LoadNote {
  id        String   @id @default(cuid())
  loadId    String
  userId    String
  userName  String
  body      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  load      Load     @relation(fields: [loadId], references: [id], onDelete: Cascade)
}
